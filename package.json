{
  "name": "gvmer",
  "version": "1.0.0",
  "description": "The gaming operating system — premium desktop application",
  "author": "gvmer Inc.",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://gvmer.app",
  "repository": "github:thepc101/gvmer",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:main": "esbuild src/main/index.ts --bundle --platform=node --external:electron --external:electron-updater --outfile=dist/main/index.js --watch",
    "dev:preload": "esbuild src/preload/index.ts --bundle --platform=node --external:electron --outfile=dist/preload/index.js --watch",
    "dev:renderer": "vite",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\"",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --external:electron --external:electron-updater --outfile=dist/main/index.js --minify-whitespace --minify-syntax && node -e \"require('fs').copyFileSync(require.resolve('sql.js/dist/sql-wasm.wasm'), 'dist/main/sql-wasm.wasm')\"",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --external:electron --outfile=dist/preload/index.js --minify-whitespace --minify-syntax",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "npm run build && electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:win:sign": "npm run build && electron-builder --win --x64 --config.forceCodeSigning",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux --x64",
    "publish": "npm run build && electron-builder --win --x64 --publish always",
    "analyze": "vite build --analyze"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.0.0",
    "framer-motion": "^11.0.0",
    "groq-sdk": "^1.3.0",
    "livekit-client": "^2.20.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^6.3.0"
  }
}
