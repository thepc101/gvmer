# =============================================================================
# gvmer — Code Signing Configuration (EXAMPLE)
# =============================================================================
# Copy this file to electron-builder.env and fill in your values.
# NEVER commit the actual .env file with secrets.
#
# Windows Authenticode signing:
#   CSC_LINK=C:\path\to\your\certificate.p12
#   CSC_KEY_PASSWORD=your-certificate-password
#   WIN_CSC_LINK=%CSC_LINK%
#   WIN_CSC_KEY_PASSWORD=%CSC_KEY_PASSWORD%
#   WIN_SIGNTOOL_PARAMS=/tr http://timestamp.digicert.com /td sha256 /fd sha256
#
# macOS signing (notarization):
#   APPLE_ID=your-apple-id@email.com
#   APPLE_APP_SPECIFIC_PASSWORD=app-specific-password
#   APPLE_TEAM_ID=your-team-id
#
# GitHub (for auto-updates):
#   GH_TOKEN=your-github-token
#
# ----------------------------------------------------------------------------
CSC_LINK=
CSC_KEY_PASSWORD=
WIN_CSC_LINK=
WIN_CSC_KEY_PASSWORD=
GH_TOKEN=
